<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.bunlong.clip</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/node</string>
        <string>/Users/bheng/Sites/clip/src/server.js</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>CLIP_NAME</key>
        <string>M4</string>
        <key>CLIP_PEER</key>
        <string>10.0.0.97:4545</string>
        <key>CLIP_TOKEN</key>
        <string>clip-sync-secret</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
